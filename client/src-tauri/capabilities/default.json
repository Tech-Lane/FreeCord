{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions with strictly scoped plugin directory access (read-only: readDir, readFile)",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "deep-link:default",
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/.freecord/plugins" },
        { "path": "$HOME/.freecord/plugins/*" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/.freecord/plugins" },
        { "path": "$HOME/.freecord/plugins/*" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/.freecord/plugins" },
        { "path": "$HOME/.freecord/plugins/*" }
      ]
    }
  ]
}
