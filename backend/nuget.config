<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!-- Clear fallback folders (e.g. Visual Studio paths); prevents Docker Linux build from failing on missing Windows paths -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
